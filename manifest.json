{
  "vendor": "madumfm2",
  "name": "appformmadu",
  "version": "0.0.5",
  "title": "form-madu",
  "description": "App para corrigir bug do formulário de contato",
  "builders": {
    "react": "3.x",
    "messages": "1.x",
    "store": "0.x",
    "styles": "2.x",
    "node": "7.x"
  },
  "dependencies": {
    "vtex.styleguide": "9.x"
  },
  "registries": ["smartcheckout"],
  "policies": [
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.vtex.com",
        "path": "/api/dataentities/*"
      }
    },
    {
      "name": "ADMIN_DS"
    }
  ],
  "$schema": "https://raw.githubusercontent.com/vtex/node-vtex-api/master/gen/manifest.schema"
}
