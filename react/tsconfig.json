{
  "extends": "@vtex/tsconfig",
  "compilerOptions": {
    "noEmitOnError": false,
    "lib": ["dom", "es2020"],
    "module": "esnext",
    "moduleResolution": "node",
    "target": "es2020",
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "./typings/*.d.ts",
    "./**/*.tsx",
    "./**/*.ts",
    "./**/*.js",
    "./**/*.jsx"
  ],
  "exclude": ["node", "dist"]
}
